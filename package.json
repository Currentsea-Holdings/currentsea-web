{
  "name": "currentsea-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-types": "swagger-typescript-api -p http://localhost:3000/api-json -o src/api/ --axios --name types.ts && node appendTypesComment.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@floating-ui/react": "^0.26.12",
    "@hookform/resolvers": "^3.3.4",
    "@preact/signals-react": "^2.0.1",
    "@tanstack/react-query": "^5.32.0",
    "autoprefixer": "^10.4.19",
    "axios": "^1.6.8",
    "classnames": "^2.5.1",
    "country-state-city": "^3.2.1",
    "flowbite": "^2.3.0",
    "flowbite-react": "^0.9.0",
    "flowbite-react-icons": "^1.0.7",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "match-sorter": "^6.3.4",
    "object-to-formdata": "^4.5.1",
    "postcss": "^8.4.38",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.3",
    "react-international-phone": "^4.2.8",
    "react-router-dom": "^6.23.0",
    "react-spinners": "^0.13.8",
    "react-toastify": "^10.0.5",
    "react-use": "^17.5.0",
    "sort-by": "^1.2.0",
    "swagger-typescript-api": "^13.0.3",
    "tailwindcss": "^3.4.3",
    "yup": "^1.4.0",
    "zustand": "^4.5.2"
  },
  "rules": {
    "react/jsx-uses-react": "off",
    "react/react-in-jsx-scope": "off",
    "react-refresh/only-export-components": "warn",
    "@typescript-eslint/no-unused-vars": "off"
  },
  "devDependencies": {
    "@hookform/devtools": "^4.3.1",
    "@storybook/addon-interactions": "^8.0.9",
    "@storybook/addon-mdx-gfm": "^8.0.9",
    "@storybook/addon-onboarding": "^8.0.9",
    "@storybook/blocks": "^8.0.9",
    "@storybook/node-logger": "^8.0.9",
    "@storybook/react-vite": "^8.0.9",
    "@storybook/test": "^8.0.9",
    "@types/eslint": "^8.56.10",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "axios-mock-adapter": "^1.22.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.1",
    "eslint-plugin-react-refresh": "^0.4.6",
    "eslint-plugin-storybook": "^0.8.0",
    "prettier": "^3.2.5",
    "prettier-plugin-classnames": "^0.6.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "simple-zustand-devtools": "^1.1.0",
    "storybook": "^8.0.9",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-checker": "^0.6.4",
    "vite-plugin-eslint": "^1.8.1"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "lint": "eslint .",
  "lint:fix": "eslint --fix",
  "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
  "packageManager": "yarn@4.0.2"
}
